<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Tugas Baru"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Input Nama Tugas -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_task_name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Nama Tugas"
            app:layout_constraintTop_toBottomOf="@id/tv_dialog_title">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_task_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Input Mata Kuliah -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_course_name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Mata Kuliah"
            app:layout_constraintTop_toBottomOf="@id/til_task_name">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_course_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Dropdown Prioritas (Material Design) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_priority"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Prioritas"
            app:layout_constraintTop_toBottomOf="@id/til_course_name">
            <AutoCompleteTextView
                android:id="@+id/actv_priority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Tombol Pilih Tanggal -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_date"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Pilih Tanggal Deadline"
            app:icon="@drawable/ic_calendar"
            app:layout_constraintTop_toBottomOf="@id/til_priority"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Tombol Simpan -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_task"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Simpan"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_pick_date" />

        <!-- Tombol Batal -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_task"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batal"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@id/btn_save_task"
            app:layout_constraintTop_toTopOf="@id/btn_save_task"
            app:layout_constraintBottom_toBottomOf="@id/btn_save_task"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>